# --- Application ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Estimation Immobilier"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CITY="Saint-Étienne"

# --- SEO / Analytics ---
NEXT_PUBLIC_SITE_TITLE="Estimation Immobilière par Ville"
NEXT_PUBLIC_SITE_DESCRIPTION="Estimez rapidement le prix de votre bien immobilier en fonction de votre ville."
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# --- API / Backend ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080/api"
API_INTERNAL_BASE_URL="http://localhost:8080/api"
API_TIMEOUT_MS=10000

# --- Auth / Session (si nécessaire) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# --- Base de données (si utilisée côté serveur Next) ---
DATABASE_URL="mysql://user:password@localhost:3306/estimation"

# --- E-mail / Lead capture ---
MAIL_FROM="noreply@estimation.local"
MAIL_TO_LEADS="contact@estimation.local"
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""

# --- Feature flags ---
NEXT_PUBLIC_ENABLE_FAVORIS=true
NEXT_PUBLIC_ENABLE_LEAD_CAPTURE=true

# --- Rate limiting / Sécurité ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
