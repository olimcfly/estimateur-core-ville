# Application
APP_NAME="Estimateur Immobilier"
APP_BASE_URL=https://example.com

# Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=estimateur
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Site / Ville (duplication multi-ville)
SITE_CITY=
SITE_CITY_SLUG=
SITE_ZIP=
SITE_REGION=
SITE_COUNTRY=France
SITE_DOMAIN=example.com

# Moteur d'estimation
# Prix de base au m² pour la ville configurée.
# Utilisé dans EstimationService comme point de départ du calcul.
# Valeur par défaut : 4200.0 (à adapter selon le marché local du site).
# Ajuster selon le marché réel avant chaque déploiement.
SITE_CITY_FACTOR=1.0
SITE_CITY_BASELINE_PRICE=4200.0

# Couleurs (thème)
SITE_COLOR_PRIMARY=#1f6f8b
SITE_COLOR_PRIMARY_DARK=#174f64
SITE_COLOR_ACCENT=#22a06b
SITE_COLOR_ACCENT_LIGHT=#4bc48b
SITE_COLOR_BG=#faf9f7
SITE_COLOR_SURFACE=#ffffff
SITE_COLOR_TEXT=#1a1410
SITE_COLOR_MUTED=#6b6459
SITE_COLOR_BORDER=#e8dfd7
SITE_COLOR_SUCCESS=#22c55e
SITE_COLOR_WARNING=#f97316
SITE_COLOR_DANGER=#e24b4a
SITE_COLOR_INFO=#3b82f6
SITE_COLOR_NEUTRAL=#000000

# E-mail (SMTP)
MAIL_FROM_ADDRESS=contact@example.com
MAIL_FROM_NAME="Estimateur Immobilier"
MAIL_ADMIN_EMAIL=admin@example.com
MAIL_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=
MAIL_SMTP_PASS=
MAIL_ENCRYPTION=tls

# E-mail (IMAP)
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_USER=
MAIL_IMAP_PASS=
MAIL_IMAP_ENCRYPTION=ssl

# Google
GOOGLE_MAPS_API_KEY=
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=

# Analytics
# GTM_ID doit être défini dans la table settings (admin) pour chaque ville.
# Ne pas le définir ici pour éviter les fuites cross-site.

# APIs IA (optionnel)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# SMS
SMSPARTNER_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_RETRY_AFTER=3600

# Leads
LEAD_STRICT_IP=true

# Ville (legacy — à migrer vers SITE_*)
CITY_NAME=
CITY_REGION=
CITY_CODE_POSTAL=
CITY_QUARTIERS=
CITY_PRIX_M2=4200
