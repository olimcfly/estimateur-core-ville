# ==============================
# Application
# ==============================
APP_NAME="Estimation Immobilier [VILLE]"
APP_BASE_URL="https://estimation-immobilier-[ville].fr"
WEBSITE_ID=1

# ==============================
# Database
# ==============================
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="[user]_esti-mmo-[ville]"
DB_USER="[user]_esti-immo-[ville]-user"
DB_PASS=""
DB_CHARSET="utf8mb4"

# ==============================
# SMTP (Sortant)
# ==============================
MAIL_DRIVER="smtp"
MAIL_HOST="bus.o2switch.net"
MAIL_PORT="465"
MAIL_USERNAME="contact@estimation-immobilier-[ville].fr"
MAIL_PASSWORD=""
MAIL_ENCRYPTION="ssl"
MAIL_FROM_ADDRESS="contact@estimation-immobilier-[ville].fr"
MAIL_FROM_NAME="Estimation Immobilier [VILLE]"
MAIL_FROM="no-reply@estimation-immobilier-[ville].fr"

# ==============================
# IMAP (Entrant)
# ==============================
IMAP_HOST="bus.o2switch.net"
IMAP_PORT="993"
IMAP_USERNAME="contact@estimation-immobilier-[ville].fr"
IMAP_PASSWORD=""
IMAP_ENCRYPTION="ssl"

# ==============================
# APIs
# ==============================
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
PERPLEXITY_ENDPOINT="https://api.perplexity.ai/chat/completions"

OPENAI_API_KEY=""

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

GOOGLE_API_KEY=""
GSC_CLIENT_ID=""
GSC_CLIENT_SECRET=""

# Ville
CITY_NAME="[VILLE]"
CITY_REGION="[RÉGION]"
CITY_CODE_POSTAL="[CP]"
CITY_QUARTIERS="[QUARTIER_1],[QUARTIER_2],[QUARTIER_3]"
CITY_PRIX_M2=0

# Couleurs
SITE_COLOR_PRIMARY="#8B1538"
SITE_COLOR_PRIMARY_DARK="#6b0f2d"
SITE_COLOR_ACCENT="#D4AF37"
SITE_COLOR_ACCENT_LIGHT="#E8C547"
# ==============================
# Maintenance
# ==============================
MAINTENANCE_MODE=false
MAINTENANCE_RETRY_AFTER=3600
DEV_SKIP_AUTH=false
